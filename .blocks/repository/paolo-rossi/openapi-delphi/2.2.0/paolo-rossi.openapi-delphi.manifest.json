  "version": "2.2.0",
  "description": "OpenAPI 3.0 document generator and parser for Delphi",
  "license": "Apache-2.0",
  "homepage": "https://github.com/paolo-rossi/OpenAPI-Delphi",
  "repository": {
    "type": "github",
    "url": "https://github.com/paolo-rossi/OpenAPI-Delphi/tree/v2.2.0"
  },
  "author": "Paolo Rossi",
  "keywords": ["OpenAPI", "swagger", "JSON"],
